# Supabase — Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — Project Settings > API. Server-only, never expose
# to the browser. Used to bootstrap clinics and invite teammates.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Base URL used to build email confirmation / password reset links.
# Optional locally (falls back to the request host); set explicitly in
# production (e.g. https://app.esteticaos.com).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
